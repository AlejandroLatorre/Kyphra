# Copy to .env and fill in. NEVER commit .env.
#
# This file is for the developer machine (the one running the Kyphra hook).
# Admin-only secrets (Supabase service role key, Anthropic API key) live in
# Cloudflare Workers secrets, NOT in this .env. See SECURITY.md T11/T12.

# --- Kyphra runtime ---
# URL of the Cloudflare Worker that fronts the classifier. The client never
# calls Anthropic directly.
KYPHRA_CLASSIFIER_ENDPOINT=https://kyphra-classifier.example.workers.dev

# Home for local state (logs, config). Defaults to ~/.kyphra
KYPHRA_HOME=

# Set to 1 to use the stub classifier (no API calls). Defaults to 1 until the
# Worker endpoint is live.
KYPHRA_STUB=1

# --- Dashboard (admin-only machines) ---
# Public anon key for the admin dashboard to talk to Supabase with RLS.
# Never place the service_role key here.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# --- Admin-only machines (not developer machines) ---
# Password used to derive the AES-GCM key that decrypts local ALERTA archives
# for review. Only set on admin machines. On developer machines this stays unset.
KYPHRA_ADMIN_PASSWORD=
